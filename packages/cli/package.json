{
  "name": "@withy/cli",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "withy": "./bin/index.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm clean && tsc -p tsconfig.build.json && pnpm copy:assets",
    "clean": "node scripts/clean.mjs",
    "copy:assets": "node scripts/copy-assets.mjs",
    "dev": "tsx src/index.ts",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "@withy/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
